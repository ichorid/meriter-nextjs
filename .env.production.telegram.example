# Production Telegram MVP — copy to /opt/meriter/.env on prod VPS
# DO NOT commit real secrets. BOT_TOKEN lives only on the server.

DOMAIN=meriter.pro
COMMUNITY_DOMAIN=community-dobro.meriter.pro
COMMUNITY_WEB_BASE_URL=https://community-dobro.meriter.pro

MERITER_PRODUCT_MODE=telegram_mvp
TELEGRAM_BOT_ENABLED=true
OAUTH_TELEGRAM_ENABLED=true

BOT_USERNAME=meriter_bot
BOT_TOKEN=

JWT_SECRET=
MONGO_ADMIN_PASSWORD=
MONGO_APP_PASSWORD=

# Optional: pin release images (CI sets sha-* on deploy from main)
# VERSION_API=0.64.1
# VERSION_COMMUNITY_WEB=0.4.0
