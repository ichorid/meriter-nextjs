# Dev VPS Telegram pilot — copy relevant lines to /opt/meriter/.env on dev server.
# Bot: @meriter_bot · webhook: https://dev.meriter.pro/api/telegram/hooks/meriter_bot
# Canonical pilot DB: MongoDB on dev VPS (back up before major upgrades).

DOMAIN=dev.meriter.pro
COMMUNITY_DOMAIN=community-dev.meriter.pro
COMMUNITY_WEB_BASE_URL=https://community-dev.meriter.pro

MERITER_PRODUCT_MODE=telegram_mvp
TELEGRAM_BOT_ENABLED=true
OAUTH_TELEGRAM_ENABLED=true
BOT_USERNAME=meriter_bot
OAUTH_TELEGRAM_BOT_USERNAME=meriter_bot
BOT_TOKEN=
