## Key Patterns

### Service Layer (Backend)
```typescript
// domain/services/[entity].service.ts вҖ” new code uses persistence ports, not @InjectModel
@Injectable()
export class EntityService {
  constructor(
    @Inject(ENTITY_PERSISTENCE_PORT) private readonly persistence: EntityPersistencePort,
    private otherService: OtherService,
  ) {}

  async create(dto: CreateEntityDto): Promise<Entity> {
    // business rules + persistence port
  }
}
// Tier-3 exception: migration scripts / tg-bots may still use @InjectModel (tagged V-12-residual)
```

### tRPC Router (Backend)
```typescript
// trpc/routers/[entity].router.ts
export const entityRouter = router({
  getById: protectedProcedure
    .input(z.object({ id: z.string() }))
    .query(async ({ ctx, input }) => {
      return ctx.entityService.getById(input.id);
    }),
});
```

### Component Pattern (Frontend)
```typescript
// components/[feature]/FeatureCard.tsx
interface FeatureCardProps {
  data: FeatureData;
  onAction?: () => void;
}

export function FeatureCard({ data, onAction }: FeatureCardProps) {
  // Component logic
}
```

