# Copy to .env.development.local for local dev.
# Leave NEXT_PUBLIC_API_URL empty — Next.js rewrites proxy /trpc/community → localhost:8002 (same-origin, no CORS).
# NEXT_PUBLIC_API_URL=

# Optional: same stable id as API seed (autoseed fills devCommunityId via getConfig when unset)
# NEXT_PUBLIC_DEFAULT_COMMUNITY_ID=a1000001-0000-4000-8000-000000000001
