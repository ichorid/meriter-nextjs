# Canonical Telegram pilot on dev VPS (159.223.212.122 / dev.meriter.pro).
# Real users interact with @meriter_bot; MongoDB on this VPS is the pilot database.
# BOT_TOKEN: set on server (/opt/meriter/.env) or GitHub dev environment secret BOT_TOKEN.

DOMAIN=dev.meriter.pro
COMMUNITY_DOMAIN=community-dev.meriter.pro
COMMUNITY_WEB_BASE_URL=https://community-dev.meriter.pro

MERITER_PRODUCT_MODE=telegram_mvp
TELEGRAM_BOT_ENABLED=true
SENTRY_TRACES_SAMPLE_RATE=0.1
SENTRY_PROFILES_SAMPLE_RATE=0
OAUTH_TELEGRAM_ENABLED=true
BOT_USERNAME=meriter_bot
OAUTH_TELEGRAM_BOT_USERNAME=meriter_bot
