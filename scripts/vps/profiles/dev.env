# Non-secret Telegram settings for dev VPS (159.223.212.122 / dev.meriter.pro).
# BOT_TOKEN stays in /opt/meriter/.env on the server — never commit it.
# MERITER_PRODUCT_MODE intentionally omitted: dev runs full Meriter + dev bot side-by-side.

DOMAIN=dev.meriter.pro
COMMUNITY_DOMAIN=community-dev.meriter.pro
COMMUNITY_WEB_BASE_URL=https://community-dev.meriter.pro

TELEGRAM_BOT_ENABLED=true
OAUTH_TELEGRAM_ENABLED=true
BOT_USERNAME=meriter_dev1_bot
OAUTH_TELEGRAM_BOT_USERNAME=meriter_dev1_bot
