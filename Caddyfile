# Caddyfile for Meriter application
# Replace {$DOMAIN} with your actual domain or use environment variable

# Enable admin API for reloading without restart (only accessible from localhost)
{
	admin localhost:2019
}

(meriter_security_headers) {
	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
		X-Content-Type-Options "nosniff"
		X-Frame-Options "DENY"
		X-XSS-Protection "1; mode=block"
		Referrer-Policy "strict-origin-when-cross-origin"
		Permissions-Policy "geolocation=(), microphone=(), camera=(), payment=(), usb=()"
		# Telegram Login Widget: script from telegram.org; OAuth iframe oauth.telegram.org
		Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval' https://telegram.org https://api.telegram.org https://fonts.googleapis.com https://backend-ambered-tidepool-6732.fly.dev; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data: https: blob:; connect-src 'self' https://telegram.org https://api.telegram.org https://oauth.telegram.org https://backend-ambered-tidepool-6732.fly.dev wss://backend-ambered-tidepool-6732.fly.dev; frame-src 'self' https://oauth.telegram.org;"
		-Server
	}
}

# Support both HTTP and HTTPS for localhost development
{$DOMAIN} {
    # Enable access logs
    log {
        output stdout
        level INFO
    }

    import meriter_security_headers

    # Rate limiting for API endpoints (stricter limits)
    # Note: Caddy v2 doesn't have built-in rate limiting - requires caddy-ratelimit plugin
    # To enable rate limiting, build Caddy with: xcaddy build --with github.com/mholt/caddy-ratelimit
    # For now, rate limiting is configured but will be ignored without the plugin
    # Alternative: Use Caddy's built-in request limiting via reverse_proxy timeouts
    handle /api* {
        # Rate limiting configuration (requires caddy-ratelimit plugin)
        # Uncomment and configure when plugin is installed:
        # rate_limit {
        #     zone api_zone {
        #         key {remote_host}
        #         events 100
        #         window 1m
        #     }
        # }
        
        # Add rate limit headers
        header {
            X-RateLimit-Limit "100"
            X-RateLimit-Window "60"
        }
        
        reverse_proxy api:8002 {
            header_up X-Real-IP {remote_host}
            header_up X-Forwarded-For {remote_host}
            header_up X-Forwarded-Proto {scheme}
            header_up X-Forwarded-Host {host}
        }
        encode gzip
    }

    handle /trpc* {
        reverse_proxy api:8002 {
            header_up X-Real-IP {remote_host}
            header_up X-Forwarded-For {remote_host}
            header_up X-Forwarded-Proto {scheme}
            header_up X-Forwarded-Host {host}
        }
        encode gzip
    }

    # Web app (serverful Next.js)
    handle {
        # Add rate limit headers
        header {
            X-RateLimit-Limit "200"
            X-RateLimit-Window "60"
        }
        reverse_proxy web:8001 {
            header_up X-Real-IP {remote_host}
            header_up X-Forwarded-For {remote_host}
            header_up X-Forwarded-Proto {scheme}
            header_up X-Forwarded-Host {host}
        }
    }
    
    encode gzip
}

# Community-web (Telegram MVP) — isolated product on subdomain
{$COMMUNITY_DOMAIN:community-meriter.pro} {
    log {
        output stdout
        level INFO
    }

    import meriter_security_headers

    handle /api* {
        reverse_proxy api:8002 {
            header_up X-Real-IP {remote_host}
            header_up X-Forwarded-For {remote_host}
            header_up X-Forwarded-Proto {scheme}
            header_up X-Forwarded-Host {host}
        }
        encode gzip
    }

    handle /trpc* {
        reverse_proxy api:8002 {
            header_up X-Real-IP {remote_host}
            header_up X-Forwarded-For {remote_host}
            header_up X-Forwarded-Proto {scheme}
            header_up X-Forwarded-Host {host}
        }
        encode gzip
    }

    handle {
        reverse_proxy community-web:8003 {
            header_up X-Real-IP {remote_host}
            header_up X-Forwarded-For {remote_host}
            header_up X-Forwarded-Proto {scheme}
            header_up X-Forwarded-Host {host}
        }
    }

    encode gzip
}
